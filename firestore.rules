rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super-admin'];
    }

    // Bookings: Users can read, but only admins can delete/write
    match /bookings/{document=**} {
      allow read: if isAuthenticated();
      allow write, delete: if isAdmin();
    }

    // Users: Each user can read all, but only admins can write
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write, delete: if isAdmin() || request.auth.uid == userId;
    }
    
    // Mail Queue: Only admins can create/delete (script has service account permissions)
    match /mail_queue/{docId} {
      allow read: if isAdmin();
      allow delete: if isAdmin();
      allow create: if isAuthenticated();
    }

    // Audit Log: Only admins can read, app can create
    match /audit_log/{docId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
  }
}
